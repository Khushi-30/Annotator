PORT=8787

# AWS S3 — when these are all set, uploads go to S3 instead of api/data/uploads.
# Leave unset for local-disk dev mode.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# Optional: CDN/custom domain in front of the bucket. If unset, URLs are built as
# https://{bucket}.s3.{region}.amazonaws.com/{key} — requires the bucket to allow
# public reads (see README S3 setup notes).
S3_PUBLIC_BASE_URL=
# By default the API returns signed S3 GET URLs to the browser. Set to false only
# when the bucket/CDN is intentionally public and anonymous GETs are verified.
S3_SIGNED_URLS=true
S3_SIGNED_URL_EXPIRES_SECONDS=604800

# Max images processed (sharp + S3 upload) concurrently per upload request.
MAX_CONCURRENT_UPLOADS=8
